#!/bin/bash
### BEGIN INIT INFO
# Provides:          sacaoos
# Required-Start:    $network $remote_fs
# Required-Stop:     $network $remote_fs
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: SecAIOS Telegram Bot
# Description:       Cybersecurity AI Operating System with OpenCode Agent
### END INIT INFO

NAME=sacaoos
DESC="SecAIOS Telegram Bot"
PIDFILE=/var/run/$NAME.pid
SCRIPT=/opt/sacaoos/execution/telegram/opencode_bot.py
USER=aios
LOG=/var/log/$NAME.log

start() {
    echo "Starting $DESC: "
    cd /opt/sacaoos
    start-stop-daemon -S -c $USER -m -p $PIDFILE -b -o \
        -d /opt/sacaoos \
        -e "PYTHONUNBUFFERED=1" \
        -e "OPENCODE_SERVER_PASSWORD=$(grep OPENCODE_SERVER_PASSWORD /opt/sacaoos/.env | cut -d= -f2)" \
        -- python3 $SCRIPT >> $LOG 2>&1
    echo "Done"
}

stop() {
    echo "Stopping $DESC: "
    start-stop-daemon -K -p $PIDFILE -o
    rm -f $PIDFILE
    echo "Done"
}

status() {
    if [ -f $PIDFILE ]; then
        echo "$NAME is running (PID: $(cat $PIDFILE))"
    else
        echo "$NAME is not running"
    fi
}

case "$1" in
    start) start ;;
    stop) stop ;;
    restart) stop; sleep 2; start ;;
    status) status ;;
    *) echo "Usage: $0 {start|stop|restart|status}" ;;
esac

exit 0