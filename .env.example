# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_user_id_here

# OpenCode Server Configuration
OPENCODE_SERVER=http://localhost:4096
OPENCODE_SERVER_PASSWORD=your_secure_password_here

# Model Configuration
# Options: 
#   - "big-pickle" (default, OpenCode's free model)
#   - "ollama/qwen3:14b" (local, private)
#   - "ollama/llama3.2:8b" (local, lighter)
#   - "anthropic/claude-sonnet-4-..." (requires API key)
#   - "openai/gpt-4o" (requires API key)
DEFAULT_MODEL=big-pickle
SENSITIVE_MODEL=ollama/qwen3:14b

# Ollama Configuration (for sensitive mode)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# Switch to sensitive/local model for confidential work
# Use /model command in Telegram to switch
# /model big-pickle  - Uses OpenCode's default (faster, less private)
# /model ollama      - Uses local Ollama (slower, 100% private)

# Caido Configuration
CAIDO_URL=http://localhost:8080
CAIDO_AUTH_TOKEN=your_caido_token_here

# Browser Harness Configuration
BROWSER_HARNESS_PATH=/opt/browser-harness
CHROME_STEALTH_PORT=9333

# Data OS Configuration
DATABASE_PATH=./data/aios.db

# Web Search (optional)
# SEARXNG_URL=http://localhost:8888